# EcoPulse Climate Guide - environment variables
# Copy to .env and fill in before running.

# ---------------------------------------------------------------
# Ollama - local model (primary path, no API key needed)
# ---------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=ecopulse-guide          # the custom model built from Modelfile.ecopulse
OLLAMA_BASE_MODEL=phi4-mini          # used by climate_llm.py's extraction helpers only

# ---------------------------------------------------------------
# Gemini - fallback when Ollama is not running
# Get a free key at https://aistudio.google.com/apikey
# ---------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------
# Bot API server (bot/server.py)
# ---------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# Android emulator → host at 10.0.2.2:8000 (hardcoded default in ClimateApiService.kt)
# Physical device on same Wi-Fi → set CLIMATE_API_URL in app/.env.example to LAN IP

# Comma-separated list of allowed CORS origins for production.
# Defaults to "*" if not set.
ALLOWED_ORIGINS=*
